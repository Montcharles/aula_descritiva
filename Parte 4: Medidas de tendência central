  labs(title = "Boxplot da Massa",
       y = "Massa (g)", x = "") +
  theme_minimal(base_size = 14)

# 3) Boxplot de Envergadura
p_env <- ggplot(morfometria, aes(y = Envergadura_cm)) +
  geom_boxplot(fill = "#22c55e", color = "black", alpha = 0.8) +
  labs(title = "Boxplot da Envergadura",
       y = "Envergadura (cm)", x = "") +
