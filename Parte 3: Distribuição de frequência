library(dplyr)

# ----- FREQUÊNCIAS PARA VARIÁVEIS QUALITATIVAS -----

# Frequência absoluta - Espécies
freq_especies <- table(morfometria$Espécie)
print("Frequência Absoluta de Espécies:")
print(freq_especies)

# Frequência relativa (proporção)
freq_rel_especies <- prop.table(freq_especies)
print("Frequência Relativa de Espécies:")
print(round(freq_rel_especies, 3))

# Frequência percentual
freq_perc_especies <- prop.table(freq_especies) * 100
print("Frequência Percentual de Espécies:")
print(round(freq_perc_especies, 2))

# Frequência por Habitat
freq_habitat <- table(morfometria$Habitat)
print("Frequência por Habitat:")
print(freq_habitat)


# Gerar os gráficos de frequência

library(ggplot2)

# Histograma do Comprimento
ggplot(morfometria, aes(x = Comprimento_cm)) +
  geom_histogram(bins = 10, fill = "#3498db", color = "black") +
  labs(title = "Distribuição do Comprimento",
       x = "Comprimento (cm)", y = "Frequência") +
  theme_minimal()

# Histograma da Massa
ggplot(morfometria, aes(x = Massa_g)) +
  geom_histogram(bins = 10, fill = "#e74c3c", color = "black") +
  labs(title = "Distribuição da Massa",
       x = "Massa (g)", y = "Frequência") +
  theme_minimal()

# Histograma da Envergadura
ggplot(morfometria, aes(x = Envergadura_cm)) +
  geom_histogram(bins = 10, fill = "#2ecc71", color = "black") +
  labs(title = "Distribuição da Envergadura",
       x = "Envergadura (cm)", y = "Frequência") +
  theme_minimal()


#Se quiser comparar por espécie:

ggplot(morfometria, aes(x = Massa_g)) +
