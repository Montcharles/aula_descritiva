###########################################################
# 7. Histogramas com densidade (3 gráficos lado a lado)
###########################################################
library(gridExtra) # Load the gridExtra package

p_comp <- ggplot(morfometria, aes(x = Comprimento_cm)) +
  geom_histogram(aes(y = after_stat(density)), bins = 10,
                 fill = "#3498db", color = "black") +
  labs(title = "Comprimento", x = "Comprimento (cm)",
       y = "Frequência relativa") +
  theme_minimal()

p_massa <- ggplot(morfometria, aes(x = Massa_g)) +
  geom_histogram(aes(y = after_stat(density)), bins = 10,
                 fill = "#e74c3c", color = "black") +
  labs(title = "Massa", x = "Massa (g)",
       y = "Frequência relativa") +
  theme_minimal()

p_env <- ggplot(morfometria, aes(x = Envergadura_cm)) +
  geom_histogram(aes(y = after_stat(density)), bins = 10,
                 fill = "#2ecc71", color = "black") +
  labs(title = "Envergadura", x = "Envergadura (cm)",
       y = "Frequência relativa") +
  theme_minimal()

grid.arrange(p_comp, p_massa, p_env, nrow = 1)

# Versão com tema customizado + densidade
tema <- theme_minimal(base_size = 14) +
  theme(
    panel.grid.major = element_line(color = "grey85"),
    panel.grid.minor = element_blank(),
    plot.title      = element_text(face = "bold", hjust = 0.5),
    axis.title      = element_text(face = "bold"),
    axis.text       = element_text(color = "grey20")
  )

p_comp <- ggplot(morfometria, aes(x = Comprimento_cm)) +
  geom_histogram(aes(y = after_stat(density)), bins = 8,
                 fill = "#38bdf8", color = "white", alpha = 0.9) +
  geom_density(color = "#0f766e", linewidth = 1) +
  labs(title = "Comprimento das Aves",
       x = "Comprimento (cm)", y = "Frequência relativa") +
  tema

p_massa <- ggplot(morfometria, aes(x = Massa_g)) +
  geom_histogram(aes(y = after_stat(density)), bins = 8,
                 fill = "#f97316", color = "white", alpha = 0.9) +
  geom_density(color = "#c2410c", linewidth = 1) +
  labs(title = "Massa Corporal",
       x = "Massa (g)", y = "Frequência relativa") +
  tema

p_env <- ggplot(morfometria, aes(x = Envergadura_cm)) +
  geom_histogram(aes(y = after_stat(density)), bins = 8,
                 fill = "#22c55e", color = "white", alpha = 0.9) +
  geom_density(color = "#15803d", linewidth = 1) +
  labs(title = "Envergadura",
       x = "Envergadura (cm)", y = "Frequência relativa") +
  tema

grid.arrange(p_comp, p_massa, p_env, nrow = 1)

###########################################################
# 8. Média, mediana e moda da Massa + linhas verticais
###########################################################
media_massa   <- mean(morfometria$Massa_g)
mediana_massa <- median(morfometria$Massa_g)

calcular_moda <- function(x) {
  ux <- unique(x)
  ux[which.max(tabulate(match(x, ux)))]
}
moda_massa <- calcular_moda(morfometria$Massa_g)

media_massa; mediana_massa; moda_massa

ggplot(morfometria, aes(x = Massa_g)) +
  geom_histogram(bins = 10, fill = "#38bdf8", color = "white", alpha = 0.9) +
  geom_vline(xintercept = media_massa,
             color = "#ef4444", linetype = "dashed", linewidth = 1.1) +
  geom_vline(xintercept = mediana_massa,
             color = "#22c55e", linetype = "dotted", linewidth = 1.1) +
  geom_vline(xintercept = moda_massa,
             color = "#6366f1", linetype = "dotdash", linewidth = 1.1) +
  labs(title = "Massa das aves: média, mediana e moda",
       x = "Massa (g)", y = "Frequência") +
  annotate("text", x = media_massa,   y = Inf, vjust = 2,
           label = paste0("Média = ", round(media_massa, 1)),
           color = "#ef4444", fontface = "bold", angle = 90, size = 4) +
  annotate("text", x = mediana_massa, y = Inf, vjust = 2,
           label = paste0("Mediana = ", round(mediana_massa, 1)),
           color = "#22c55e", fontface = "bold", angle = 90, size = 4) +
  annotate("text", x = moda_massa,    y = Inf, vjust = 2,
           label = paste0("Moda = ", round(moda_massa, 1)),
           color = "#6366f1", fontface = "bold", angle = 90, size = 4) +
  theme_minimal(base_size = 14)

