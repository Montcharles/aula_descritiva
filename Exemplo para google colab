###########################################################
# 10. Boxplots conjuntos (pivot_longer -> pivot_longer)
###########################################################
morf_long <- morfometria %>%
  dplyr::select(Comprimento_cm, Massa_g, Envergadura_cm) %>%
  pivot_longer(cols = everything(),
               names_to = "Variavel",
               values_to = "Valor")

ggplot(morf_long, aes(x = Variavel, y = Valor, fill = Variavel)) +
  geom_boxplot(alpha = 0.8, color = "black") +
  labs(title = "Boxplots das Variáveis Morfométricas",
       x = "Variável", y = "Valor") +
  scale_fill_manual(values = c("Comprimento_cm" = "#38bdf8",
                               "Massa_g"        = "#f97316",
                               "Envergadura_cm" = "#22c55e")) +
  theme_minimal(base_size = 14) +
  theme(legend.position = "none",
        axis.text.x = element_text(angle = 20, hjust = 1))

