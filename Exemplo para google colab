# 11.  Assimetria e curtose com 'moments'
###########################################################

# instalar uma vez por sessão (se ainda não instalou):
install.packages("moments")

# carregar o pacote
library(moments)

# calcular assimetria e curtose de Massa_g
skew_massa  <- skewness(morfometria$Massa_g, na.rm = TRUE)
kurt_massa  <- kurtosis(morfometria$Massa_g, na.rm = TRUE)  # curtose total (não excesso)

skew_massa
kurt_massa
