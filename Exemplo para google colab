# 4. Tabelas de frequência
###########################################################
freq_especies <- table(morfometria$Espécie)
cat("Frequência Absoluta de Espécies:\n")
print(freq_especies)

freq_rel_especies  <- prop.table(freq_especies)
freq_perc_especies <- freq_rel_especies * 100

cat("\nFrequência Relativa de Espécies:\n")
